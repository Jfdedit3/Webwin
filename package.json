{
  "name": "webwin-gallery",
  "version": "1.0.0",
  "description": "A Windows photo gallery app built with Electron",
  "main": "main.js",
  "author": "Jfdedit3",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder --win",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.jfdedit3.webwingallery",
    "productName": "Webwin Gallery",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Webwin Gallery"
    }
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  }
}
